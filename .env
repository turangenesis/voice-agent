# Secrets live in 1Password (Dev vault), NOT here. These are references.
# Run any command with:  op run --env-file=.env -- python3 <script>
# op resolves these pointers to real values in memory only. Safe to commit.

# LiveKit (voice agent). Fill the item once via: lk cloud auth -> op item edit
LIVEKIT_URL=op://Dev/LiveKit/url
LIVEKIT_API_KEY=op://Dev/LiveKit/api_key
LIVEKIT_API_SECRET=op://Dev/LiveKit/api_secret

# Moss (retrieval) — used by both ingest.py and voice_agent.py
MOSS_PROJECT_ID=op://Dev/Moss/project_id
MOSS_PROJECT_KEY=op://Dev/Moss/project_key

# Anthropic (only for the HTTP API's /ask answer-composing — v3 Path B; NOT used by voice).
# Fill once: paste your key from console.anthropic.com into the Anthropic item in the Dev vault.
ANTHROPIC_API_KEY=op://Dev/Anthropic/api_key

# Non-secret config
MOSS_INDEX=docs
ANTHROPIC_MODEL=claude-haiku-4-5
